rson Language Associates Quality Reviewer Training Materials*"},"meta":{"source_file":"intro-to-quality-reviews-sample.md","text_name":"intro-to-quality-reviews-sample","type":"text_for_annotation","created_date":"2025-10-02T14:44:00.672334","converter":"md_to_json_converter"},"created_at":"2026-03-19T20:28:12.306226Z","updated_at":"2026-03-19T22:27:17.550318Z","inner_id":1,"total_annotations":2,"cancelled_annotations":0,"total_predictions":0,"comment_count":0,"unresolved_comment_count":0,"last_comment_updated_at":null,"project":112,"updated_by":110,"comment_authors":[]}]